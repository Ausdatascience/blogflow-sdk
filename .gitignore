# Dependencies
node_modules/

# Build output (should not be committed - users install from npm)
dist/
*.tsbuildinfo

# Packaged files (should not be committed - use npm publish instead)
*.tgz
*.tar.gz

# Lock files (optional - some projects commit these, but for SDKs it's usually ignored)
# Uncomment if you want to commit lock files
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp

